OPERATOR_USERNAME=operator
OPERATOR_PASSWORD_HASH=
OPERATOR_TOTP_SECRET=
SESSION_SECRET=change-this-session-secret
PII_ENCRYPTION_KEY=64_hex_chars_encryption_key
RETENTION_DAYS=90
# 상담 신청 DB 보관 일수. 동의문의「약 3개월」과 맞추려면 90 전후 권장(환경에 맞게 조정).
DUPLICATE_LEAD_WINDOW_HOURS=24
AGREEMENT_VERSION=v2.0
PURGE_ON_STARTUP=true
PURGE_SCHEDULE_HOUR=3
DB_HEALTHCHECK_TIMEOUT_MS=2000
ERROR_ALERT_WEBHOOK_URL=
ERROR_ALERT_COOLDOWN_SEC=60
NODE_ENV=development
TRUST_PROXY=1
PHONE_HASH_HMAC_KEY=change-this-phone-hmac-key
DATABASE_URL=
# Railway: postgres.railway.internal 이 ENOTFOUND 이면 Postgres Connect의 Public TCP URL 전체를 넣음
DATABASE_PUBLIC_URL=
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
# 배포 시 (Render, Railway 등)
# PORT=10000
# 운영 필수: DATABASE_URL 또는 DATABASE_PUBLIC_URL, SESSION_SECRET, PII_ENCRYPTION_KEY, OPERATOR_PASSWORD_HASH, OPERATOR_TOTP_SECRET, PHONE_HASH_HMAC_KEY
